# Cognito hosted UI base URL
VITE_API_URL=https://cognito-idp.us-east-1.amazonaws.com

# AWS Cognito
VITE_AWS_COGNITO_POOL_ID=us-east-1_xxxxxxxxx
VITE_AWS_COGNITO_CLIENT_ID=<your-cognito-client-id>

# OAuth redirect after sign-in
VITE_OAUTH_SIGN_IN_REDIRECT_URL=http://localhost:5173/

# Fragments API URL — pick one:
# VITE_FRAGMENT_API_URL=http://localhost: #local
# VITE_FRAGMENT_API_URL=http://<ec2-public-dns>:8080 # prod
VITE_FRAGMENT_API_URL=http://<your-load-balancer-url>
