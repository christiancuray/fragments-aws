# Server
PORT=8080

# Log level: debug | info | silent
LOG_LEVEL=debug

# AWS Cognito
AWS_COGNITO_POOL_ID=us-east-1_xxxxxxxxx
AWS_COGNITO_CLIENT_ID=<your-cognito-client-id>

# AWS Region (optional, defaults to us-east-1)
# AWS_REGION=us-east-1

# Basic auth (local dev only)
# HTPASSWD_FILE=./tests/.htpasswd

# Secret hash for token signing
SECRET_HASH=<your-secret-hash>
